# -----------------------------------------------
# Copy this file to .env and fill in your values
# -----------------------------------------------

# Local development (default)
VITE_API_BASE_URL=http://localhost:8000/api/admin
VITE_STORAGE_BASE_URL=http://localhost:8000/storage

# LAN access (replace with your machine IP)
# VITE_API_BASE_URL=http://192.168.1.62:8000/api/admin
# VITE_STORAGE_BASE_URL=http://192.168.1.62:8000/storage

# Production / ngrok tunnel
# VITE_API_BASE_URL=https://your-domain.com/api/admin
# VITE_STORAGE_BASE_URL=https://your-domain.com/storage

VITE_APP_NAME=Inventory Management System
VITE_APP_PORT=8080
